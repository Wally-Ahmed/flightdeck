# Flightdeck — environment template. Copy to `.env` and fill real values (`.env` is gitignored).
# Aligned to apps/orchestrator/src/config.ts. The orchestrator boots without any of these;
# each is needed only for its own step.

# ── REQUIRED for the live factory ────────────────────────────────────────────
# AI agents (spec / code / verify / review).   https://platform.openai.com  → API Keys
OPENAI_API_KEY=sk-REPLACE_ME

# GitHub PAT — clone the fork, push a branch, open the PR + comment.
# github.com → Settings → Developer settings → Personal access tokens (classic) → scope: repo
# (also tick write:packages IF we use the Docker-image preview path)
GITHUB_TOKEN=ghp_REPLACE_ME
# YOUR fork of superplanehq/superplane, written as owner/repo
GITHUB_REPO=your-username/superplane

# Render API key — deploys the per-issue previews.  Render → Account Settings → API Keys
RENDER_API_KEY=rnd_REPLACE_ME
# Render workspace/owner id (tea-… or usr-…). Optional — auto-detected from the key if blank.
RENDER_OWNER_ID=

# ── For the REAL Superplane canvas (fill after you create the app) ───────────
SUPERPLANE_URL=https://app.superplane.com
# Profile → API token (a service-account token is best for automation)
SUPERPLANE_API_TOKEN=REPLACE_ME
# The canvas/app id — exists after `superplane apps create` + pushing the canvas
SUPERPLANE_CANVAS_ID=REPLACE_ME
# The trigger node id in the canvas (default is correct)
SUPERPLANE_TRIGGER_NODE_ID=ingest
# UUID of the OpenAI integration inside Superplane (`superplane integrations list`).
# The canvas import REQUIRES this id — a name is rejected.
OPENAI_INTEGRATION_ID=REPLACE_ME

# Used by superplane/render-canvas.sh when it pushes the canvas:
ORCH_URL=                 # the deployed orchestrator URL (fill once it's live on Render)
CANVAS_ID=                # same value as SUPERPLANE_CANVAS_ID

# ── Optional / has a sensible default ────────────────────────────────────────
# Postgres connection string. Blank ⇒ in-memory run store (fine for the demo).
DATABASE_URL=
PORT=3000
# Set to 1 to force the safe #5368 canned diff instead of the live agent (demo insurance).
FLIGHTDECK_FORCE_CANNED=

# ── Dashboard (Vite) ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
# true = mock data (offline demo) · false = read the live orchestrator
VITE_USE_MOCK=true
