# Run board (Vite) — environment.
#
# The board reads GET /api/runs. By DEFAULT it serves a local mock fixture so the
# static build is self-contained and demos offline. To point it at the LIVE
# orchestrator (Phase 2 "swap the board to live"), set:
#
#   VITE_USE_MOCK=false
#   VITE_API_BASE=https://flightdeck-orchestrator.onrender.com   # the deployed orchestrator
#
# VITE_API_URL is accepted as an alias for VITE_API_BASE (it's the name render.yaml
# injects for the deployed static site), so on Render you can set either —
# `VITE_USE_MOCK=false` + `VITE_API_URL=<orchestrator url>` flips the board live
# with no code change. Copy this to `.env` (gitignored) for local live testing
# against a locally-running orchestrator:
#
#   VITE_USE_MOCK=false
#   VITE_API_BASE=http://localhost:3000

VITE_USE_MOCK=true
VITE_API_BASE=
