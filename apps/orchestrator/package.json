{
  "name": "@flightdeck/orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Flightdeck orchestrator — ingests the issue, hosts the coding agent, exposes the /stages/* endpoints the canvas calls, manages fork/branch/PR, calls Render, serves the run board API.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "node --watch --import tsx src/index.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@flightdeck/contracts": "*",
    "@octokit/rest": "^21.1.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^6.45.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
